# ── Frontend (Vite — safe to expose) ─────────────────────────────────────────

# Clerk Authentication (https://dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Supabase (https://supabase.com/dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Sentry (Error Monitoring) — https://sentry.io → New Project → React → DSN
# Opcional: sem isso, erros não são reportados automaticamente
VITE_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# ── Supabase Edge Function secrets ────────────────────────────────────────────
# Set via CLI: supabase secrets set KEY=value
# Or via Supabase Dashboard → Edge Functions → Secrets
# NEVER put these in .env or commit them to git
#
# OPENAI_API_KEY=sk-...
# CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
#
# Mercado Pago (https://www.mercadopago.com.br/developers)
# MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...
# MERCADO_PAGO_WEBHOOK_SECRET=<secret gerado no painel MP → Webhooks → Chave secreta>
#   ⚠️  OBRIGATÓRIO em produção: sem este secret, qualquer pessoa pode ativar premium gratuitamente
#
# APP_URL=https://your-app.netlify.app
