<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              App Links for the Mercado Pago checkout return (back_urls).
              Today the checkout opens in an in-app browser (@capacitor/browser)
              and the payment success/failure page is a plain https URL — without
              this, Android just shows that page in the browser tab instead of
              reopening the native app.

              Once FeynLearn has a real production domain (APP_URL in the
              Edge Functions' env), uncomment this block with that host, AND
              host the matching assetlinks.json at:
                https://<your-domain>/.well-known/assetlinks.json
              containing your release keystore's SHA-256 fingerprint
              (get it with: keytool -list -v -keystore your.keystore).
              Without a verified assetlinks.json, autoVerify="true" silently
              fails and the fallback behavior described above stays in place.

            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="YOUR_PRODUCTION_DOMAIN" android:pathPrefix="/pricing" />
            </intent-filter>
            -->

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Voice Mode (Whisper transcription) records audio via getUserMedia()
         inside the WebView; see MainActivity's onPermissionRequest handler
         for the runtime permission grant that also has to happen. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
</manifest>
